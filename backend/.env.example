# Credenciales de Google OAuth2 (Descargadas de Google Cloud Console -> Desktop Credentials)
# NOTA: Debes guardar el archivo JSON descargado en `backend/credentials.json`
# No es necesario poner claves del cliente aquí si usas el archivo credentials.json,
# pero si prefieres usar variables puras, aquí tienes los campos principales:

# GOOGLE_CLIENT_ID=tucid.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=tu-secreto
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Firebase Admin SDK
# Guarda la clave privada de tu cuenta de servicio de Firebase Admin en `backend/serviceAccountKey.json`
# Como alternativa, puedes inyectar como base64 el JSON entero en servidores reales:
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Configuración del Sincronizador
# Etiquetas opcionales a modificar en Gmail tras leer (Ej. CRM_SYNCED)
SYNC_LABEL_NAME=CRM_SYNCED
